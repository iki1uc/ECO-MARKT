<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>ECO‑MARKT 3D Raum</title>

<style>
body {
    background:#000;
    color:#0f0;
    font-family:monospace;
    overflow:hidden;
}
#eco3d {
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    width:400px;
    height:400px;
    border:2px solid #0f0;
    border-radius:50%;
    animation:pulse 1.5s infinite;
}
@keyframes pulse {
    0% { opacity:0.3; transform:scale(0.9); }
    50% { opacity:1; transform:scale(1.1); }
    100% { opacity:0.3; transform:scale(0.9); }
}
.vector {
    position:absolute;
    color:#0ff;
    font-size:14px;
}
</style>

<script src="eco.js"></script>

<script>
window.onload = () => {
    const box = document.getElementById("eco3d");

    ecoVectors.forEach(v => {
        const div = document.createElement("div");
        div.className = "vector";
        div.style.left = (200 + v.ist.x*10) + "px";
        div.style.top  = (200 - v.ist.y*10) + "px";
        div.textContent = v.name + " Δ(" + v.delta.x + "," + v.delta.y + "," + v.delta.z + ")";
        box.appendChild(div);
    });
};
</script>
</head>

<body>
<div id="eco3d"></div>
</body>
</html>
