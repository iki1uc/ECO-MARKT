<div id="ecoVec"></div>

<script>
function ecoVector(soll, ist) {
    const dx = ist.x - soll.x;
    const dy = ist.y - soll.y;
    const dz = ist.z - soll.z;

    return `Δ = (${dx}, ${dy}, ${dz})`;
}

setInterval(()=>{
    const soll = {x:12, y:4, z:9};
    const ist  = {x:10 + Math.random()*2, y:5, z:7 + Math.random()*2};

    document.getElementById("ecoVec").textContent =
        "ECO‑MARKT Vektor: " + ecoVector(soll, ist);
}, 300);
</script>
